        },
        {
          "listen": "test",
          "script": {
            "id": "9a0ec7e5-af95-4027-93e4-22c314a25c97",
            "exec": [
              "let jsonData = pm.response.json();",
              "",
              "pm.test(\"Statuscode is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Data contains at least one country\", function () {",
              "    pm.expect(Object.keys(jsonData).length).to.be.greaterThan(0);",
              "});",
              "",
              "",
              "pm.test(\"Response time is fast\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
